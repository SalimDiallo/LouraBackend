### Global Variables
@baseUrl = http://localhost:8000/api
@coreUrl = {{baseUrl}}/core
@hrUrl = {{baseUrl}}/hr

### ======================================
### SETUP
### ======================================
@email = admin@gmail.com
@password = Max1234@

# LOGIN to get Access Token
# --------------------------------------------------------
POST {{baseUrl}}/auth/admin/login/
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### VARIABLES (Update after login/creation)
# --------------------------------------------------------
@accessToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ0b2tlbl90eXBlIjoiYWNjZXNzIiwiZXhwIjoxNzY3Mzk1NDc4LCJpYXQiOjE3NjczOTQ1NzgsImp0aSI6ImUzMzFmMTliZTkzOTQ2YmVhY2Y1M2UyNTYwYjM2MDNiIiwidXNlcl9pZCI6ImI3NjkyMWFjLWUyODEtNGJhNS1iMjQ4LWQ1M2EzN2M0NDdiYiJ9.lV1sPzZ6Y-vChp-2l7iVfD9L1F2k9YI-h4K7Yk0K3w0
@orgId = fa12c6dd-7ace-4d76-8385-e1d7ad6bb92a
# Subdomain of the created organization
@orgSubdomain = my-super-organization-e892d1


### ======================================
### 1. DEPARTMENTS
### ======================================

### 1.1 Create Engineering Department
POST {{hrUrl}}/departments/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "organization": "{{orgId}}",
  "name": "Direction Technique",
  "code": "TECH",
  "description": "Département en charge de la technologie et du développement"
}

### 1.2 Create HR Department
POST {{hrUrl}}/departments/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "organization": "{{orgId}}",
  "name": "Ressources Humaines",
  "code": "RH",
  "description": "Gestion du personnel"
}

### 1.3 List Departments
GET {{hrUrl}}/departments/?organization={{orgId}}
Authorization: Bearer {{accessToken}}


### ======================================
### 2. POSITIONS
### ======================================

### 2.1 Create Developer Position
POST {{hrUrl}}/positions/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "organization": "{{orgId}}",
  "title": "Développeur Senior",
  "code": "DEV-SENIOR",
  "description": "Développement backend et frontend",
  "min_salary": 5000000,
  "max_salary": 12000000
}

### 2.2 Create HR Manager Position
POST {{hrUrl}}/positions/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "organization": "{{orgId}}",
  "title": "Responsable RH",
  "code": "HR-MGR",
  "description": "Gestion de l'équipe RH",
  "min_salary": 6000000,
  "max_salary": 15000000
}

### 2.3 List Positions
GET {{hrUrl}}/positions/?organization={{orgId}}
Authorization: Bearer {{accessToken}}


### ======================================
### 3. ROLES (Authentication/Permissions)
### ======================================

### 3.1 List System Roles
GET {{hrUrl}}/roles/?organization={{orgId}}&is_system_role=true
Authorization: Bearer {{accessToken}}


### ======================================
### 4. EMPLOYEES
### ======================================

# IMPORTANT: Replace @departmentId and @positionId with real UUIDs from previous responses
@departmentId = REPLACE_WITH_DEPT_UUID
@positionId = REPLACE_WITH_POS_UUID

### 4.1 Create Employee (Standard)
POST {{hrUrl}}/employees/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "organization": "{{orgId}}",
  "email": "moussa.diallo@example.com",
  "password": "Password123!",
  "password_confirm": "Password123!",
  "first_name": "Moussa",
  "last_name": "Diallo",
  "phone": "+224620101010",
  "employee_id": "EMP-001",
  "gender": "M",
  "date_of_birth": "1995-05-15",
  "address": "Hamdallaye",
  "city": "Conakry",
  "country": "GN",
  "hire_date": "2024-01-01",
  "employment_status": "active",
  "department": "{{departmentId}}",
  "position": "{{positionId}}"
}


### 4.2 List Employees
GET {{hrUrl}}/employees/?organization={{orgId}}
Authorization: Bearer {{accessToken}}

### 4.3 Get Employee Detail
@employeeId = REPLACE_WITH_EMPLOYEE_ID
GET {{hrUrl}}/employees/{{employeeId}}/?organization={{orgId}}
Authorization: Bearer {{accessToken}}


### ======================================
### 5. CONTRACTS
### ======================================

### 5.1 Create Contract (CDI)
POST {{hrUrl}}/contracts/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "employee": "{{employeeId}}",
  "contract_type": "cdi",
  "start_date": "2024-01-01",
  "base_salary": 8500000,
  "currency": "GNF",
  "salary_period": "monthly",
  "hours_per_week": 40,
  "description": "Contrat à durée indéterminée",
  "is_active": true
}

### 5.2 List Contracts
GET {{hrUrl}}/contracts/?organization={{orgId}}
Authorization: Bearer {{accessToken}}


### ======================================
### 6. LEAVE TYPES
### ======================================

### 6.1 Create Annual Leave
POST {{hrUrl}}/leave-types/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "organization": "{{orgId}}",
  "name": "Congé Annuel",
  "code": "ANNUAL",
  "default_days_per_year": 30,
  "is_paid": true,
  "requires_approval": true,
  "color": "#eab308"
}

### 6.2 Create Sick Leave
POST {{hrUrl}}/leave-types/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "organization": "{{orgId}}",
  "name": "Maladie",
  "code": "SICK",
  "default_days_per_year": 10,
  "is_paid": true,
  "requires_approval": false,
  "color": "#ef4444"
}

### 6.3 List Leave Types
GET {{hrUrl}}/leave-types/?organization={{orgId}}
Authorization: Bearer {{accessToken}}