### ======================================
### 1. CORE AUTHENTICATION ENDPOINTS
### ======================================

### 1.1 Register - Inscription d'un nouvel administrateur
# Note: The register endpoint is located in the Core app/urls
POST {{coreUrl}}/auth/register/
Content-Type: application/json

{
  "email": "admin@gmail.com",
  "password": "SecurePass123!",
  "password_confirm": "SecurePass123!",
  "first_name": "Admin",
  "last_name": "Gmail",
  "phone": "+224620000000"
}

### ======================================
### 2. HELPER AUTH ENDPOINTS (from Auth App)
### ======================================
# These are necessary to get tokens for testing Core endpoints

### 2.1 Login Admin
POST {{authUrl}}/admin/login/
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### 2.2 Get Current User
GET {{authUrl}}/me/
Authorization: Bearer {{accessToken}}


### ======================================
### 3. ORGANIZATIONS ENDPOINTS
### ======================================

### 3.1 List Organizations - Lister toutes les organisations de l'admin connecte
GET {{coreUrl}}/organizations/
Authorization: Bearer {{accessToken}}


### 3.2 Create Organization - Créer une nouvelle organisation
POST {{coreUrl}}/organizations/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "Test Organization",
  "subdomain": "test-org-123",
  "category": 1,
  "settings": {
    "currency": "GNF",
    "country": "GN",
    "contact_email": "info@test-org.com"
  }
}

### 3.3 Get Organization Details
GET {{coreUrl}}/organizations/{{orgId}}/
Authorization: Bearer {{accessToken}}


### 3.4 Update Organization (PUT)
PUT {{coreUrl}}/organizations/{{orgId}}/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "Organisation Mise a Jour",
  "subdomain": "org-updated-123",
  "category": 1,
  "is_active": true,
  "settings": {
    "currency": "USD",
    "country": "US",
    "theme": "dark",
    "contact_email": "contact@org-updated.com"
  }
}


### 3.5 Update Organization (PATCH)
PATCH {{coreUrl}}/organizations/{{orgId}}/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "Nouveau Nom Organisation"
}


### 3.6 Activate Organization
POST {{coreUrl}}/organizations/{{orgId}}/activate/
Authorization: Bearer {{accessToken}}


### 3.7 Deactivate Organization
POST {{coreUrl}}/organizations/{{orgId}}/deactivate/
Authorization: Bearer {{accessToken}}


### 3.8 Upload Organization Logo
# Note: REST Client requires file path for multipart forms
POST {{coreUrl}}/organizations/{{orgId}}/logo/
Authorization: Bearer {{accessToken}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="logo"; filename="logo.png"
Content-Type: image/png

< ./logo.png
--boundary--


### 3.9 Delete Organization Logo
DELETE {{coreUrl}}/organizations/{{orgId}}/logo/
Authorization: Bearer {{accessToken}}


### 3.10 Delete Organization (Soft Delete)
DELETE {{coreUrl}}/organizations/{{orgId}}/
Authorization: Bearer {{accessToken}}


### ======================================
### 4. CATEGORIES ENDPOINTS (Read-Only)
### ======================================
### 4.0 Create Category
POST {{coreUrl}}/categories/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "Commerce",
  "description": "Gestion des produits et services de commerce "
}

### 4.1 List Categories
GET {{coreUrl}}/categories/
Authorization: Bearer {{accessToken}}


### 4.2 Get Category Details
GET {{coreUrl}}/categories/1/
Authorization: Bearer {{accessToken}}
